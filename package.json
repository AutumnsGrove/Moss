{
  "name": "moss",
  "version": "0.1.0",
  "private": true,
  "description": "Quiet, always-on AI assistant on Cloudflare Workers",
  "type": "module",
  "scripts": {
    "dev": "wrangler dev",
    "deploy": "wrangler deploy",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "schema": "wrangler d1 execute moss-db --local --file=scripts/schema.sql",
    "schema:remote": "wrangler d1 execute moss-db --file=scripts/schema.sql",
    "compile-skills": "tsx scripts/compile-skills.ts"
  },
  "dependencies": {
    "toml": "^3.0.0"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20250224.0",
    "typescript": "^5.7.3",
    "vitest": "^3.0.7",
    "wrangler": "^3.109.2",
    "tsx": "^4.19.2"
  }
}
